  <property name="styleSheet">
   <string notr="true">/* 主窗口背景 */
QDialog {
    background-color: #f5f7fa;
    font-family: 'Microsoft YaHei', Arial;
}

/* 标题样式 */
QLabel#titleLabel {
    font-size: 24px;
    font-weight: bold;
    color: #2c3e50;
    margin: 10px;
}

QLabel#subtitleLabel {
    font-size: 14px;
    color: #7f8c8d;
    margin-bottom: 30px;
}

/* 输入框样式 */
QLineEdit {
    border: 2px solid #dfe6e9;
    border-radius: 8px;
    padding: 10px 15px;
    font-size: 14px;
    background-color: white;
    min-height: 20px;
}

QLineEdit:focus {
    border-color: #3498db;
    background-color: #f8fafc;
}

QLineEdit[error=&quot;true&quot;] {
    border-color: #e74c3c;
    background-color: #fff5f5;
}

/* 按钮样式 */
QPushButton {
    border: none;
    border-radius: 8px;
    padding: 12px 0;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
}

QPushButton#loginButton {
    background-color: #3498db;
    color: white;
    margin-top: 10px;
}

QPushButton#loginButton:hover {
    background-color: #2980b9;
}

QPushButton#loginButton:pressed {
    background-color: #21618c;
}

QPushButton#loginButton:disabled {
    background-color: #bdc3c7;
    color: #7f8c8d;
}

QPushButton#guestButton {
    background-color: #2ecc71;
    color: white;
}

QPushButton#guestButton:hover {
    background-color: #27ae60;
}

QPushButton#forgotButton {
    background-color: transparent;
    color: #3498db;
    text-decoration: underline;
    padding: 5px;
}

/* 标签样式 */
QLabel {
    font-size: 14px;
    color: #2c3e50;
}

/* 复选框样式 */
QCheckBox {
    font-size: 13px;
    color: #34495e;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
}

QCheckBox::indicator:unchecked {
    border: 2px solid #bdc3c7;
    border-radius: 4px;
    background-color: white;
}

QCheckBox::indicator:checked {
    border: 2px solid #3498db;
    border-radius: 4px;
    background-color: #3498db;
    image: url(:/icons/check.svg);
}

/* 状态标签 */
QLabel#statusLabel {
    font-size: 12px;
    color: #e74c3c;
    min-height: 16px;
}

/* 分割线 */
QFrame#divider {
    border: 1px solid #dfe6e9;
    max-height: 1px;
}</string>
