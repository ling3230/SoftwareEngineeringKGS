          <item>
           <widget class="QPlainTextEdit" name="detailContent">
            <property name="styleSheet">
             <string notr="true">/* 选中 detailContent，设置样式表 */
QPlainTextEdit {
    background-color: #f5f9ff;  /* 蓝 */
    border: none;
    font-size: 14px;
