<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>软件工程知识图谱 - 个性化学习系统</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* 全局样式 */
    QMainWindow {
       background-color: #3498db;
    }

    /* 标题栏样式 */
    #titleBar {
        background-color: #2c3e50;
        min-height: 60px;
        max-height: 60px;
        border-bottom: 2px solid #34495e;
    }

    #titleBar QLabel {
        color: white;
        font-size: 14px;
    }

    #mainTitleLabel {
        font-size: 20px;
        font-weight: bold;
        color: #ecf0f1;
        padding-left: 20px;
    }

    #userInfoLabel {
        background-color: #34495e;
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: bold;
    }

    #careerLabel {
        background-color: #3498db;
        padding: 5px 15px;
        border-radius: 15px;
        color: white;
        font-weight: bold;
    }

    /* 侧边栏样式 */
    #sideBar {
        background-color: white;
        border-right: 1px solid #e0e0e0;
    }

    #sideBar QLabel[text*=&quot;职业&quot;] {
        font-size: 16px;
        font-weight: bold;
        color: #2c3e50;
        padding: 15px 10px 5px 20px;
    }

    /* 知识点树样式 */
    #knowledgeTree {
        border: none;
        background-color: #f8fbff;
        font-size: 13px;
        outline: none;
        padding: 6px 8px 10px 8px;
    }

    #knowledgeTree::item {
        padding: 8px 10px;
        margin: 3px 4px;
        border-radius: 6px;
    }

    #knowledgeTree::item:selected {
        background-color: #d8ebff;
        color: #16324f;
        border: 1px solid #8ebce6;
    }

    #knowledgeTree::item:hover {
        background-color: #eef6ff;
    }

    QHeaderView::section {
        background-color: #edf4fb;
        color: #47627d;
        border: none;
        border-bottom: 1px solid #d7e2ee;
        padding: 8px 10px;
        font-size: 12px;
        font-weight: bold;
    }

    #knowledgeTree::branch:has-children:!has-siblings:closed,
    #knowledgeTree::branch:closed:has-children:has-siblings {
        border-image: none;
        image: url(:/icons/arrow-right.png);
    }

    #knowledgeTree::branch:open:has-children:!has-siblings,
    #knowledgeTree::branch:open:has-children:has-siblings {
        border-image: none;
        image: url(:/icons/arrow-down.png);
    }

    /* 进度条样式 */
    QProgressBar {
        border: none;
        background-color: #ecf0f1;
        border-radius: 5px;
        height: 8px;
        text-align: center;
    }

    QProgressBar::chunk {
        background-color: #2ecc71;
        border-radius: 5px;
    }

    /* 统计卡片样式 */
    #statsWidget {
        background-color: #f8f9fa;
        border-top: 1px solid #e0e0e0;
        padding: 10px;
    }

    .statCard {
        background-color: white;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 10px;
    }

    .statCard QLabel {
        color: #7f8c8d;
        font-size: 12px;
    }

    .statCard QLabel[text*=&quot;0&quot;] {
        color: #2c3e50;
        font-size: 24px;
        font-weight: bold;
    }

    /* 按钮样式 */
    QPushButton {
        background-color: #3498db;
        color: white;
        border: none;
        border-radius: 5px;
        padding: 8px 16px;
        font-size: 13px;
        font-weight: bold;
    }

    QPushButton:hover {
        background-color: #2980b9;
    }

    QPushButton#refreshBtn {
        background-color: #95a5a6;
    }

    QPushButton#refreshBtn:hover {
        background-color: #7f8c8d;
    }

    QPushButton#studyBtn {
        background-color: #2ecc71;
    }

    QPushButton#studyBtn:hover {
        background-color: #27ae60;
    }

    /* 详情区域样式 */
    #detailWidget {
        background-color: white;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        margin: 10px;
    }

    #detailTitle {
        font-size: 18px;
        font-weight: bold;
        color: #2c3e50;
        padding: 10px 15px;
        background-color: #f8f9fa;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
        border-bottom: 1px solid #e0e0e0;
    }

    #personaCard {
        background-color: #eef7ff;
        border-bottom: 1px solid #d8e8f6;
        padding: 8px 10px;
    }

    #personaTitleLabel {
        font-size: 13px;
        font-weight: bold;
        color: #2a5d84;
    }

    #personaSummaryLabel {
        font-size: 14px;
        color: #15324a;
        font-weight: bold;
    }

    #personaFocusLabel {
        font-size: 12px;
        color: #48657d;
    }

    #recommendPanel {
        background-color: #f8fbff;
        border-bottom: 1px solid #dbe7f2;
    }

    #recommendTitleLabel {
        font-size: 13px;
        font-weight: bold;
        color: #2a5d84;
    }

    #recommendToggleBtn {
        background-color: #2f7db8;
        border-radius: 4px;
        padding: 4px 10px;
        font-size: 12px;
    }

    #recommendToggleBtn:hover {
        background-color: #276995;
    }

    #recommendationContent {
        background-color: #ffffff;
        border: 1px solid #d9e4ee;
        border-radius: 6px;
        font-size: 13px;
        color: #2d3e4f;
        padding: 10px;
    }

    #detailContent {
        background-color: white;
        border: none;
        font-size: 14px;
        line-height: 1.6;
        padding: 15px;
    }

    /* 状态栏样式 */
    QStatusBar {
        background-color: #34495e;
        color: #ecf0f1;
    }

    QStatusBar QLabel {
        color: #ecf0f1;
        padding: 2px 10px;
    }
   </string>
