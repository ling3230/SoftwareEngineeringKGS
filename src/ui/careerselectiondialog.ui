}

QFrame#headerFrame {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #3498db, stop:1 #2c3e50);
    border-radius: 8px;
    padding: 20px;
}

QLabel#titleLabel {
    font-size: 24px;
    font-weight: bold;
    color: white;
    padding: 0;
}

QLabel#descriptionLabel {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    padding: 5px 0 0 0;
}

QFrame#contentFrame {
    background-color: white;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
}

QScrollArea {
    border: none;
    background: transparent;
}

QWidget#scrollContent {
    background: transparent;
}

QFrame.careerItem {
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    background: white;
    padding: 15px;
    margin: 5px;
}

QFrame.careerItem:hover {
    border-color: #3498db;
    background-color: #f8fafc;
}

QFrame.careerItem[selected=&quot;true&quot;] {
    border-color: #2ecc71;
    border-width: 3px;
    background-color: #f0f9ff;
}

QLabel.iconLabel {
    font-size: 32px;
    qproperty-alignment: AlignCenter;
}

QLabel.nameLabel {
    font-size: 16px;
    font-weight: bold;
    color: #2c3e50;
}

QLabel.descLabel {
    font-size: 13px;
    color: #7f8c8d;
    line-height: 1.4;
}

QRadioButton.recommendRadio {
    font-size: 12px;
    color: #e74c3c;
    font-weight: bold;
}

QFrame#footerFrame {
    background-color: white;
    border-top: 1px solid #e0e0e0;
    padding: 15px;
}

QPushButton {
    font-size: 14px;
    font-weight: bold;
    padding: 10px 25px;
    border-radius: 6px;
    border: none;
    min-width: 100px;
}

QPushButton#skipButton {
    background-color: #ecf0f1;
    color: #7f8c8d;
}

QPushButton#skipButton:hover {
    background-color: #d5dbdb;
}

QPushButton#previousButton {
    background-color: transparent;
    color: #5d6d7e;
    border: 1px solid #aeb6bf;
}

QPushButton#previousButton:hover {
    background-color: #ecf0f1;
}

QPushButton#previousButton:disabled {
    background-color: #f4f6f7;
    color: #bdc3c7;
    border: 1px solid #d5d8dc;
}

QPushButton#confirmButton {
    background-color: #2ecc71;
    color: white;
}

QPushButton#confirmButton:hover {
    background-color: #27ae60;
}

QPushButton#confirmButton:disabled {
    background-color: #bdc3c7;
}

QPushButton#settingsButton {
    background-color: transparent;
    color: #3498db;
    border: 1px solid #3498db;
}

QPushButton#settingsButton:hover {
    background-color: #3498db;
    color: white;
}

QPushButton#laterButton {
    background-color: transparent;
    color: #7f8c8d;
    border: 1px solid #bdc3c7;
}

QPushButton#laterButton:hover {
    background-color: #ecf0f1;
}</string>
